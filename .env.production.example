# =============================================================================
# Drawhaus — Production Environment Variables
#
# Backend (Kamal): Copy to .env.production and fill in real values:
#   cp .env.production.example .env.production
#
# Frontend (Cloudflare Pages): Set VITE_* vars in the Cloudflare dashboard,
#   not in this file. See README.md for details.
# =============================================================================

# --- Server ---
HOST_IP=

# --- Registry ---
# GitHub Personal Access Token with packages:write scope
# Or use GITHUB_TOKEN in CI
KAMAL_REGISTRY_PASSWORD=

# --- Frontend (set these in Cloudflare Pages, not here) ---
# VITE_API_URL=https://api.yourdomain.com
# VITE_WS_URL=https://api.yourdomain.com

# --- Backend secrets ---
DATABASE_URL=postgres://drawhaus:CHANGE_ME@localhost:5433/drawhaus_production
SESSION_SECRET=             # Generate: openssl rand -hex 32
FRONTEND_URL=https://draw.yourdomain.com
COOKIE_DOMAIN=.yourdomain.com  # Parent domain so cookies work across subdomains

# --- Postgres accessory ---
POSTGRES_PASSWORD=          # Generate: openssl rand -hex 32

# --- Email (Resend) ---
RESEND_API_KEY=             # Get from https://resend.com — leave blank to log emails to console
FROM_EMAIL=noreply@yourdomain.com