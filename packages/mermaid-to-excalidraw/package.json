{
  "name": "@drawhaus/mermaid-to-excalidraw",
  "version": "0.1.0",
  "description": "Convert Mermaid diagrams to Excalidraw elements with gradual custom converter support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "pretest": "npm run build",
    "test": "tsx --test 'src/__tests__/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "playground": "vite serve playground --config playground/vite.config.ts",
    "playground:build": "vite build --config playground/vite.config.ts"
  },
  "dependencies": {
    "@excalidraw/mermaid-to-excalidraw": "^1.1.2",
    "mermaid": "^10.9.3"
  },
  "devDependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.1.4",
    "react": "^18",
    "react-dom": "^18",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": ">=18"
  }
}
