{
  "name": "@drawhaus/helpers",
  "version": "0.1.0",
  "description": "Element builders, layout engine, and validator for Excalidraw diagrams",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "tsx --test 'src/__tests__/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'"
  },
  "dependencies": {
    "dagre": "^0.8.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.52",
    "@types/node": "^20.11.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
