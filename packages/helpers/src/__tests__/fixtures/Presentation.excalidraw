      "boundElements": [],
      "updated": 1772308042031,
      "link": null,
      "locked": false,
      "text": "Finco es una plataforma de orquestacion de pagos B2B para\nLatinoamerica. Una sola API que permite a empresas (retail,\nfintechs, bancos, wallets) ofrecer a sus usuarios finales:",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Finco es una plataforma de orquestacion de pagos B2B para Latinoamerica. Una sola API que permite a empresas (retail, fintechs, bancos, wallets) ofrecer a sus usuarios finales:",
      "autoResize": false,
      "lineHeight": 1.25
    },
