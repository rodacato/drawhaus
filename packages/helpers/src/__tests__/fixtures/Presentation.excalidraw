    },
    {
      "id": "sHRQVkP9mFoKvV2NpcsKo",
      "type": "text",
      "x": -4623.865586792595,
      "y": -5697.673761042508,
      "width": 1223.1400428213403,
      "height": 315,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e9ecef",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5J",
      "roundness": null,
      "seed": 677242206,
      "version": 1522,
      "versionNonce": 1655670174,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772307485317,
      "link": null,
      "locked": false,
      "text": "Soy Adrian Castillo, desarrollador Fullstack (Ruby/Javascript).\n\nHe trabajado en DevShops, Products, Agencies, como Freelancer y\nContractor, en varias industrias y con muchos roles: Leader,\nDeveloper a varios sabores y niveles, UI/UX, PM, PO, QA, y mas.\n\n...una carrera muy tropezada si me preguntan, pero risas no faltaron.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Soy Adrian Castillo, desarrollador Fullstack (Ruby/Javascript).\n\nHe trabajado en DevShops, Products, Agencies, como Freelancer y Contractor, en varias industrias y con muchos roles: Leader, Developer a varios sabores y niveles, UI/UX, PM, PO, QA, y mas.\n\n...una carrera muy tropezada si me preguntan, pero risas no faltaron.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "TTBf0HgTE0riS7jDROUDL",
      "type": "text",
      "x": -4648.618222884808,
      "y": -4935.346137733803,
      "width": 1223.1400428213403,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e9ecef",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5K",
      "roundness": null,
      "seed": 1886804226,
      "version": 2197,
      "versionNonce": 730438722,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772307322398,
      "link": null,
      "locked": false,
      "text": "Soy un contractor de medio tiempo que por azares del destino\ntrabaje con Iñigo y Omar en Regalli (despues Arcus, ahora no se??),\neste ultimo me invito a ayudarlo por 3 meses...",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Soy un contractor de medio tiempo que por azares del destino trabaje con Iñigo y Omar en Regalli (despues Arcus, ahora no se??),\neste ultimo me invito a ayudarlo por 3 meses...",
      "autoResize": false,
      "lineHeight": 1.25
    },
