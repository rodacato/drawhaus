{
  "name": "backend",
  "version": "0.8.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=../.env src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "db:seed": "tsx --env-file=../.env src/scripts/db-seed.ts",
    "db:reset": "tsx --env-file=../.env src/scripts/db-reset.ts",
    "test": "tsx --test --test-concurrency=1 'src/__tests__/**/*.test.ts'",
    "test:unit": "tsx --test --test-concurrency=1 'src/__tests__/unit/**/*.test.ts'",
    "test:integration": "tsx --test --test-concurrency=1 'src/__tests__/integration/**/*.test.ts'"
  },
  "dependencies": {
    "@honeybadger-io/js": "^6.12.3",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^3.0.3",
    "cookie": "^1.1.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "resend": "^6.9.3",
    "socket.io": "^4.8.3",
    "socket.io-msgpack-parser": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/cookie": "^0.6.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.18.0",
    "@types/pino": "^7.0.4",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
