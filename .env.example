# =============================================================================
# Drawhaus — Local Development Environment
#
# Copy this file to .env and fill in the values you need:
#   cp .env.example .env
#
# Docker Compose reads this file automatically. All variables are optional
# for basic development — the defaults below work out of the box.
# =============================================================================

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  DATABASE                                                                   │
# └─────────────────────────────────────────────────────────────────────────────┘
POSTGRES_DB=drawhaus
POSTGRES_USER=drawhaus
POSTGRES_PASSWORD=drawhaus

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  BACKEND — Infrastructure (required as env vars, cannot be moved to DB)     │
# │                                                                             │
# │  These are needed at server boot before the database is available.          │
# │  In production, set them as GitHub Actions secrets or in your deploy config.│
# └─────────────────────────────────────────────────────────────────────────────┘
PORT=4000
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgres://drawhaus:drawhaus@db:5432/drawhaus
SESSION_SECRET=dev-secret

# Redis (optional — leave blank to use in-memory Socket.IO adapter)
# Required for multi-container deployments
REDIS_URL=redis://redis:6379

# Encryption key for storing integration secrets in DB (optional)
# Generate with: openssl rand -hex 32
# When set, the secrets below can be configured from the admin UI
# instead of environment variables.
ENCRYPTION_KEY=

# Backup storage path (filesystem directory — must be an env var)
# Schedule, retention, and enable/disable are configured from the admin panel
# or setup wizard and stored in the database.
BACKUP_PATH=/data/backups

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  BACKEND — Integration secrets (configurable from admin UI)                 │
# │                                                                             │
# │  When ENCRYPTION_KEY is set, these can be managed from the admin panel      │
# │  (Settings → Integrations) instead of env vars. The app checks the DB      │
# │  first, then falls back to env vars.                                        │
# │                                                                             │
# │  After migrating to DB, you can remove these from env / GitHub secrets.     │
# └─────────────────────────────────────────────────────────────────────────────┘

# Google OAuth (optional — leave blank to disable Google login & Drive)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# Email (optional — leave blank to log emails to console)
# Get an API key from https://resend.com
RESEND_API_KEY=
FROM_EMAIL=noreply@drawhaus.dev

# Error monitoring (optional)
HONEYBADGER_API_KEY=

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  FRONTEND  (VITE_* vars are injected into the browser bundle)               │
# └─────────────────────────────────────────────────────────────────────────────┘
VITE_API_URL=http://localhost:4000
VITE_WS_URL=http://localhost:4000

# Google Picker API Key (optional — for Drive file import in the editor)
# Create an API key at https://console.cloud.google.com/apis/credentials
# Restrict it to "Google Picker API" only.
VITE_GOOGLE_API_KEY=
